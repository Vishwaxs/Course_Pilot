
# What to change: fill in every TODO[USER_ACTION] value below.
# Steps: 1) Copy this file to .env  2) Fill blanks  3) Restart app.

# ─── Data paths ───────────────────────────────────────────────
DATA_DIR=data/sample
# TODO[USER_ACTION]: Change DATA_DIR to your real lecture data folder when ready.

# ─── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# TODO[USER_ACTION]: REPLACE_NEO4J_PASSWORD — set a secure password and match docker-compose.yml.

# ─── Graph mode ───────────────────────────────────────────────
# Options: "neo4j" or "networkx" (in-memory fallback)
GRAPH_BACKEND=networkx

# ─── Whisper ──────────────────────────────────────────────────
WHISPER_MODEL=small
# TODO[USER_ACTION]: IF YOU WANT TO USE CLOUD_ASR_SET_PROVIDER_AND_KEY
# ASR_PROVIDER=openai          # or "assemblyai"
# ASR_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────
EMBEDDING_MODEL=all-mpnet-base-v2
# TODO[USER_ACTION]: OPTIONAL_REPLACE_WITH_HF_API_KEY if you want remote embeddings.
# HF_API_KEY=

# ─── Optional LLM for generation ─────────────────────────────
LLM_PROVIDER=local
# Options: "local" (distilbart) | "openai"
# TODO[USER_ACTION]: ADD_OPENAI_API_KEY if LLM_PROVIDER=openai
# OPENAI_API_KEY=

# ─── SSO / Campus Auth (ADVANCED) ────────────────────────────
# TODO[USER_ACTION]: CONFIGURE_SSO — set OAuth2 client credentials for campus SSO.
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_AUTHORITY_URL=

# ─── Streamlit secrets (for Streamlit Community Cloud) ────────
# When deploying to Streamlit Cloud, copy these into Settings→Secrets
# as a secrets.toml file (see README for format).
